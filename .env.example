# Root .env consumed by docker-compose. Copy to .env and fill in the blanks.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Service ports ───────────────────────────────────────────────────────────
API_PORT=3000
APP_PORT=5173
PUBLIC_PORT=3001

# ── Cross-app URLs ──────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:3001
VITE_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:5173

# ── JWT (required, 32+ chars each — generate with `openssl rand -hex 32`) ──
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── OpenAI (workers) ────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Cloudflare R2 (shared by API and workers) ───────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=hira-uploads
R2_PUBLIC_URL=https://<public-bucket-or-cdn-url>

# ── SMTP (API only) ─────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hira.com

# ── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
